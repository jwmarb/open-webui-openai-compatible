# Open WebUI connection settings
OPEN_WEBUI_URL=https://your-open-webui-instance.example.com
USER_TOKEN=<your-jwt-from-login>

# Proxy server port (overrides in docker-compose.yaml)
PORT=8000

# Upstream request timeout in seconds (10–3600)
REQUEST_TIMEOUT=300

# Max retries for empty upstream streams (0–10, 0 disables retry)
STREAM_EMPTY_RETRY_MAX=3

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
